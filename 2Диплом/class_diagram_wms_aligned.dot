digraph WMSClassDiagram {
  graph [rankdir=TB, splines=ortho, nodesep=0.55, ranksep=1.05, outputorder=edgesfirst, concentrate=false, overlap=false, bgcolor="white", pad=0.25];
  node [shape=plaintext, fontname="Arial", fontsize=10];
  edge [color="#333333", arrowsize=0.7, penwidth=1.2, fontname="Arial", fontsize=9];
  title [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="10"><TR><TD><B>Detailed Class Diagram WMS</B><BR/>aligned by project layers</TD></TR></TABLE>>, shape=plaintext];
  User [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5"><TR><TD BGCOLOR="#d9e8fc" ALIGN="CENTER"><B>User</B></TD></TR><TR><TD ALIGN="LEFT">+ username: CharField<BR ALIGN="LEFT"/>+ email: EmailField<BR ALIGN="LEFT"/>+ role: CharField<BR ALIGN="LEFT"/>+ branches: ManyToManyField<BR ALIGN="LEFT"/></TD></TR><TR><TD ALIGN="LEFT">+ is_admin()<BR ALIGN="LEFT"/>+ get_accessible_warehouses()<BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  ApiToken [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5"><TR><TD BGCOLOR="#e2f0d9" ALIGN="CENTER"><B>ApiToken</B></TD></TR><TR><TD ALIGN="LEFT">+ name: CharField<BR ALIGN="LEFT"/>+ token: CharField<BR ALIGN="LEFT"/>+ is_active: BooleanField<BR ALIGN="LEFT"/>+ user: ForeignKey<BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  Notification [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5"><TR><TD BGCOLOR="#dae8fc" ALIGN="CENTER"><B>Notification</B></TD></TR><TR><TD ALIGN="LEFT">+ user: ForeignKey<BR ALIGN="LEFT"/>+ title: CharField<BR ALIGN="LEFT"/>+ message: TextField<BR ALIGN="LEFT"/>+ is_read: BooleanField<BR ALIGN="LEFT"/></TD></TR><TR><TD ALIGN="LEFT">+ mark_read()<BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  Branch [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5"><TR><TD BGCOLOR="#fff2cc" ALIGN="CENTER"><B>Branch</B></TD></TR><TR><TD ALIGN="LEFT">+ code: CharField<BR ALIGN="LEFT"/>+ name: CharField<BR ALIGN="LEFT"/>+ address: TextField<BR ALIGN="LEFT"/>+ is_active: BooleanField<BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  Warehouse [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5"><TR><TD BGCOLOR="#fff2cc" ALIGN="CENTER"><B>Warehouse</B></TD></TR><TR><TD ALIGN="LEFT">+ branch: ForeignKey<BR ALIGN="LEFT"/>+ code: CharField<BR ALIGN="LEFT"/>+ name: CharField<BR ALIGN="LEFT"/>+ width_m: DecimalField<BR ALIGN="LEFT"/>+ length_m: DecimalField<BR ALIGN="LEFT"/>+ height_m: DecimalField<BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  WarehouseAccess [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5"><TR><TD BGCOLOR="#fff2cc" ALIGN="CENTER"><B>WarehouseAccess</B></TD></TR><TR><TD ALIGN="LEFT">+ user: ForeignKey<BR ALIGN="LEFT"/>+ warehouse: ForeignKey<BR ALIGN="LEFT"/>+ access_level: CharField<BR ALIGN="LEFT"/>+ Unique(user, warehouse)<BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  WarehouseLayout [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5"><TR><TD BGCOLOR="#d5f5f6" ALIGN="CENTER"><B>WarehouseLayout</B></TD></TR><TR><TD ALIGN="LEFT">+ warehouse: OneToOneField<BR ALIGN="LEFT"/>+ floor_points: JSONField<BR ALIGN="LEFT"/>+ gate_x: FloatField<BR ALIGN="LEFT"/>+ gate_z: FloatField<BR ALIGN="LEFT"/></TD></TR><TR><TD ALIGN="LEFT">+ gate_point<BR ALIGN="LEFT"/>+ get_floor_points_list()<BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  StorageZoneType [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5"><TR><TD BGCOLOR="#fff2cc" ALIGN="CENTER"><B>StorageZoneType</B></TD></TR><TR><TD ALIGN="LEFT">+ code: CharField<BR ALIGN="LEFT"/>+ name: CharField<BR ALIGN="LEFT"/>+ sort_order: IntegerField<BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  StorageZone [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5"><TR><TD BGCOLOR="#fff2cc" ALIGN="CENTER"><B>StorageZone</B></TD></TR><TR><TD ALIGN="LEFT">+ warehouse: ForeignKey<BR ALIGN="LEFT"/>+ zone_type: ForeignKey<BR ALIGN="LEFT"/>+ code: CharField<BR ALIGN="LEFT"/>+ name: CharField<BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  StorageLocation [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5"><TR><TD BGCOLOR="#fff2cc" ALIGN="CENTER"><B>StorageLocation</B></TD></TR><TR><TD ALIGN="LEFT">+ zone: ForeignKey<BR ALIGN="LEFT"/>+ code: CharField<BR ALIGN="LEFT"/>+ aisle: CharField<BR ALIGN="LEFT"/>+ rack: CharField<BR ALIGN="LEFT"/>+ shelf: CharField<BR ALIGN="LEFT"/>+ level: CharField<BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  StorageObject [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5"><TR><TD BGCOLOR="#d5f5f6" ALIGN="CENTER"><B>StorageObject</B></TD></TR><TR><TD ALIGN="LEFT">+ warehouse: ForeignKey<BR ALIGN="LEFT"/>+ storage_location: ForeignKey<BR ALIGN="LEFT"/>+ object_type: CharField<BR ALIGN="LEFT"/>+ position_x/y/z: FloatField<BR ALIGN="LEFT"/>+ width/depth/height: FloatField<BR ALIGN="LEFT"/></TD></TR><TR><TD ALIGN="LEFT">+ has_stock()<BR ALIGN="LEFT"/>+ get_stock_count()<BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  Brand [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5"><TR><TD BGCOLOR="#fff2cc" ALIGN="CENTER"><B>Brand</B></TD></TR><TR><TD ALIGN="LEFT">+ name: CharField<BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  Category [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5"><TR><TD BGCOLOR="#fff2cc" ALIGN="CENTER"><B>Category</B></TD></TR><TR><TD ALIGN="LEFT">+ name: CharField<BR ALIGN="LEFT"/>+ parent: ForeignKey self<BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  Product [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5"><TR><TD BGCOLOR="#fff2cc" ALIGN="CENTER"><B>Product</B></TD></TR><TR><TD ALIGN="LEFT">+ internal_sku: CharField<BR ALIGN="LEFT"/>+ name: CharField<BR ALIGN="LEFT"/>+ oem_number: CharField<BR ALIGN="LEFT"/>+ analog_number: CharField<BR ALIGN="LEFT"/>+ barcode: CharField<BR ALIGN="LEFT"/>+ brand: ForeignKey<BR ALIGN="LEFT"/>+ category: ForeignKey<BR ALIGN="LEFT"/>+ packaging_type: CharField<BR ALIGN="LEFT"/></TD></TR><TR><TD ALIGN="LEFT">+ save()<BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  ProductChangeLog [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5"><TR><TD BGCOLOR="#fff2cc" ALIGN="CENTER"><B>ProductChangeLog</B></TD></TR><TR><TD ALIGN="LEFT">+ product: ForeignKey<BR ALIGN="LEFT"/>+ changed_by: ForeignKey<BR ALIGN="LEFT"/>+ action: CharField<BR ALIGN="LEFT"/>+ changed_fields: JSONField<BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  VehicleMake [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5"><TR><TD BGCOLOR="#fff2cc" ALIGN="CENTER"><B>VehicleMake</B></TD></TR><TR><TD ALIGN="LEFT">+ name: CharField<BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  VehicleModel [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5"><TR><TD BGCOLOR="#fff2cc" ALIGN="CENTER"><B>VehicleModel</B></TD></TR><TR><TD ALIGN="LEFT">+ make: ForeignKey<BR ALIGN="LEFT"/>+ name: CharField<BR ALIGN="LEFT"/>+ Unique(make, name)<BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  ProductApplicability [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5"><TR><TD BGCOLOR="#fff2cc" ALIGN="CENTER"><B>ProductApplicability</B></TD></TR><TR><TD ALIGN="LEFT">+ product: ForeignKey<BR ALIGN="LEFT"/>+ vehicle_model: ForeignKey<BR ALIGN="LEFT"/>+ Unique(product, vehicle_model)<BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  ProductCrossReference [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5"><TR><TD BGCOLOR="#fff2cc" ALIGN="CENTER"><B>ProductCrossReference</B></TD></TR><TR><TD ALIGN="LEFT">+ from_product: ForeignKey<BR ALIGN="LEFT"/>+ to_product: ForeignKey<BR ALIGN="LEFT"/>+ relation_type: CharField<BR ALIGN="LEFT"/>+ Unique(from, to, type)<BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  Receiving [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5"><TR><TD BGCOLOR="#d5e8d4" ALIGN="CENTER"><B>Receiving</B></TD></TR><TR><TD ALIGN="LEFT">+ number: CharField<BR ALIGN="LEFT"/>+ supplier_name: CharField<BR ALIGN="LEFT"/>+ warehouse: ForeignKey<BR ALIGN="LEFT"/>+ status: CharField<BR ALIGN="LEFT"/>+ created_by: ForeignKey<BR ALIGN="LEFT"/></TD></TR><TR><TD ALIGN="LEFT">+ generate_next_number()<BR ALIGN="LEFT"/>+ save()<BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  ReceivingLine [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5"><TR><TD BGCOLOR="#d5e8d4" ALIGN="CENTER"><B>ReceivingLine</B></TD></TR><TR><TD ALIGN="LEFT">+ receiving: ForeignKey<BR ALIGN="LEFT"/>+ product: ForeignKey<BR ALIGN="LEFT"/>+ qty_expected: DecimalField<BR ALIGN="LEFT"/>+ qty_received: DecimalField<BR ALIGN="LEFT"/>+ storage_location: ForeignKey<BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  ReceivingSerial [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5"><TR><TD BGCOLOR="#d5e8d4" ALIGN="CENTER"><B>ReceivingSerial</B></TD></TR><TR><TD ALIGN="LEFT">+ line: ForeignKey<BR ALIGN="LEFT"/>+ serial_number: CharField<BR ALIGN="LEFT"/>+ Unique(line, serial_number)<BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  Stock [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5"><TR><TD BGCOLOR="#f8cecc" ALIGN="CENTER"><B>Stock</B></TD></TR><TR><TD ALIGN="LEFT">+ product: ForeignKey<BR ALIGN="LEFT"/>+ storage_location: ForeignKey<BR ALIGN="LEFT"/>+ qty_available: DecimalField<BR ALIGN="LEFT"/>+ qty_reserved: DecimalField<BR ALIGN="LEFT"/>+ batch_no: CharField<BR ALIGN="LEFT"/></TD></TR><TR><TD ALIGN="LEFT">+ qty_total<BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  StockMovement [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5"><TR><TD BGCOLOR="#f8cecc" ALIGN="CENTER"><B>StockMovement</B></TD></TR><TR><TD ALIGN="LEFT">+ movement_type: CharField<BR ALIGN="LEFT"/>+ product: ForeignKey<BR ALIGN="LEFT"/>+ quantity: DecimalField<BR ALIGN="LEFT"/>+ from_location: ForeignKey<BR ALIGN="LEFT"/>+ to_location: ForeignKey<BR ALIGN="LEFT"/>+ user: ForeignKey<BR ALIGN="LEFT"/></TD></TR><TR><TD ALIGN="LEFT">+ signed_quantity<BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  Inventory [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5"><TR><TD BGCOLOR="#f8cecc" ALIGN="CENTER"><B>Inventory</B></TD></TR><TR><TD ALIGN="LEFT">+ number: CharField<BR ALIGN="LEFT"/>+ zone: ForeignKey<BR ALIGN="LEFT"/>+ status: CharField<BR ALIGN="LEFT"/>+ created_by: ForeignKey<BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  InventoryLine [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5"><TR><TD BGCOLOR="#f8cecc" ALIGN="CENTER"><B>InventoryLine</B></TD></TR><TR><TD ALIGN="LEFT">+ inventory: ForeignKey<BR ALIGN="LEFT"/>+ product: ForeignKey<BR ALIGN="LEFT"/>+ storage_location: ForeignKey<BR ALIGN="LEFT"/>+ qty_book: DecimalField<BR ALIGN="LEFT"/>+ qty_actual: DecimalField<BR ALIGN="LEFT"/>+ discrepancy: DecimalField<BR ALIGN="LEFT"/></TD></TR><TR><TD ALIGN="LEFT">+ save()<BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  Order [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5"><TR><TD BGCOLOR="#e1d5e7" ALIGN="CENTER"><B>Order</B></TD></TR><TR><TD ALIGN="LEFT">+ number: CharField<BR ALIGN="LEFT"/>+ customer_name: CharField<BR ALIGN="LEFT"/>+ status: CharField<BR ALIGN="LEFT"/>+ priority: CharField<BR ALIGN="LEFT"/>+ created_by: ForeignKey<BR ALIGN="LEFT"/>+ picked_by: ForeignKey<BR ALIGN="LEFT"/></TD></TR><TR><TD ALIGN="LEFT">+ generate_next_number()<BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  OrderLine [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5"><TR><TD BGCOLOR="#e1d5e7" ALIGN="CENTER"><B>OrderLine</B></TD></TR><TR><TD ALIGN="LEFT">+ order: ForeignKey<BR ALIGN="LEFT"/>+ product: ForeignKey<BR ALIGN="LEFT"/>+ qty_ordered: DecimalField<BR ALIGN="LEFT"/>+ qty_picked: DecimalField<BR ALIGN="LEFT"/>+ price: DecimalField<BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  Backorder [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5"><TR><TD BGCOLOR="#fff2cc" ALIGN="CENTER"><B>Backorder</B></TD></TR><TR><TD ALIGN="LEFT">+ order: ForeignKey<BR ALIGN="LEFT"/>+ product: ForeignKey<BR ALIGN="LEFT"/>+ qty_ordered: DecimalField<BR ALIGN="LEFT"/>+ qty_fulfilled: DecimalField<BR ALIGN="LEFT"/>+ status: CharField<BR ALIGN="LEFT"/></TD></TR><TR><TD ALIGN="LEFT">+ qty_remaining<BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  PickingTask [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5"><TR><TD BGCOLOR="#e1d5e7" ALIGN="CENTER"><B>PickingTask</B></TD></TR><TR><TD ALIGN="LEFT">+ order: ForeignKey<BR ALIGN="LEFT"/>+ status: CharField<BR ALIGN="LEFT"/>+ priority: CharField<BR ALIGN="LEFT"/>+ zone_type_code: CharField<BR ALIGN="LEFT"/>+ assigned_to: ForeignKey<BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  PickingLine [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5"><TR><TD BGCOLOR="#e1d5e7" ALIGN="CENTER"><B>PickingLine</B></TD></TR><TR><TD ALIGN="LEFT">+ task: ForeignKey<BR ALIGN="LEFT"/>+ order_line: ForeignKey<BR ALIGN="LEFT"/>+ stock: ForeignKey<BR ALIGN="LEFT"/>+ qty_picked: DecimalField<BR ALIGN="LEFT"/>+ scanned_oem: CharField<BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  Task [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5"><TR><TD BGCOLOR="#eeeeee" ALIGN="CENTER"><B>Task</B></TD></TR><TR><TD ALIGN="LEFT">+ task_type: CharField<BR ALIGN="LEFT"/>+ status: CharField<BR ALIGN="LEFT"/>+ priority: CharField<BR ALIGN="LEFT"/>+ receiving: ForeignKey<BR ALIGN="LEFT"/>+ inventory: ForeignKey<BR ALIGN="LEFT"/>+ order: ForeignKey<BR ALIGN="LEFT"/>+ picking_task: ForeignKey<BR ALIGN="LEFT"/>+ assigned_to: ForeignKey<BR ALIGN="LEFT"/></TD></TR><TR><TD ALIGN="LEFT">+ can_be_assigned_to()<BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  TaskComment [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5"><TR><TD BGCOLOR="#eeeeee" ALIGN="CENTER"><B>TaskComment</B></TD></TR><TR><TD ALIGN="LEFT">+ task: ForeignKey<BR ALIGN="LEFT"/>+ author: ForeignKey<BR ALIGN="LEFT"/>+ text: TextField<BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  ABCXYZAnalysis [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5"><TR><TD BGCOLOR="#f4cccc" ALIGN="CENTER"><B>ABCXYZAnalysis</B></TD></TR><TR><TD ALIGN="LEFT">+ product: ForeignKey<BR ALIGN="LEFT"/>+ period_start: DateField<BR ALIGN="LEFT"/>+ period_end: DateField<BR ALIGN="LEFT"/>+ abc_class: CharField<BR ALIGN="LEFT"/>+ xyz_class: CharField<BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  DeadStockReport [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5"><TR><TD BGCOLOR="#f4cccc" ALIGN="CENTER"><B>DeadStockReport</B></TD></TR><TR><TD ALIGN="LEFT">+ product: ForeignKey<BR ALIGN="LEFT"/>+ stock: ForeignKey<BR ALIGN="LEFT"/>+ qty_available: DecimalField<BR ALIGN="LEFT"/>+ days_without_movement: IntegerField<BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  PickingError [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5"><TR><TD BGCOLOR="#f4cccc" ALIGN="CENTER"><B>PickingError</B></TD></TR><TR><TD ALIGN="LEFT">+ order_line: ForeignKey<BR ALIGN="LEFT"/>+ picking_line: ForeignKey<BR ALIGN="LEFT"/>+ expected_product: ForeignKey<BR ALIGN="LEFT"/>+ actual_product: ForeignKey<BR ALIGN="LEFT"/>+ detected_by: ForeignKey<BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  DemandForecast [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="5"><TR><TD BGCOLOR="#f4cccc" ALIGN="CENTER"><B>DemandForecast</B></TD></TR><TR><TD ALIGN="LEFT">+ product: ForeignKey<BR ALIGN="LEFT"/>+ forecast_date: DateField<BR ALIGN="LEFT"/>+ forecasted_qty: DecimalField<BR ALIGN="LEFT"/>+ confidence_level: DecimalField<BR ALIGN="LEFT"/>+ calculated_by: ForeignKey<BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  { rank=same; User; ApiToken; Notification; }
  { rank=same; Branch; Warehouse; WarehouseAccess; WarehouseLayout; }
  { rank=same; StorageZoneType; StorageZone; StorageLocation; StorageObject; }
  { rank=same; Brand; Category; Product; ProductChangeLog; }
  { rank=same; VehicleMake; VehicleModel; ProductApplicability; ProductCrossReference; }
  { rank=same; Receiving; ReceivingLine; ReceivingSerial; Stock; StockMovement; }
  { rank=same; Inventory; InventoryLine; Order; OrderLine; Backorder; }
  { rank=same; PickingTask; PickingLine; Task; TaskComment; }
  { rank=same; ABCXYZAnalysis; DeadStockReport; PickingError; DemandForecast; }
  User -> ApiToken;
  User -> Notification;
  User -> WarehouseAccess;
  User -> Receiving;
  User -> Inventory;
  User -> Order;
  User -> PickingTask;
  User -> Task;
  Branch -> Warehouse;
  User -> Branch;
  Warehouse -> WarehouseAccess;
  Warehouse -> WarehouseLayout;
  Warehouse -> StorageZone;
  StorageZoneType -> StorageZone;
  StorageZone -> StorageLocation;
  Warehouse -> StorageObject;
  StorageLocation -> StorageObject;
  Brand -> Product;
  Category -> Product;
  Category -> Category;
  Product -> ProductChangeLog;
  User -> ProductChangeLog;
  VehicleMake -> VehicleModel;
  Product -> ProductApplicability;
  VehicleModel -> ProductApplicability;
  Product -> ProductCrossReference;
  Warehouse -> Receiving;
  Receiving -> ReceivingLine;
  Product -> ReceivingLine;
  StorageLocation -> ReceivingLine;
  ReceivingLine -> ReceivingSerial;
  Product -> Stock;
  StorageLocation -> Stock;
  Product -> StockMovement;
  StorageLocation -> StockMovement;
  User -> StockMovement;
  StorageZone -> Inventory;
  Inventory -> InventoryLine;
  Product -> InventoryLine;
  StorageLocation -> InventoryLine;
  Order -> OrderLine;
  Product -> OrderLine;
  Order -> Backorder;
  Product -> Backorder;
  Order -> PickingTask;
  PickingTask -> PickingLine;
  OrderLine -> PickingLine;
  Stock -> PickingLine;
  Receiving -> Task;
  Inventory -> Task;
  Order -> Task;
  PickingTask -> Task;
  Task -> TaskComment;
  User -> TaskComment;
  Product -> ABCXYZAnalysis;
  Product -> DeadStockReport;
  Stock -> DeadStockReport;
  OrderLine -> PickingError;
  PickingLine -> PickingError;
  Product -> PickingError;
  Product -> DemandForecast;
  User -> DemandForecast;
  User -> ApiToken [style=invis, weight=20];
  ApiToken -> Notification [style=invis, weight=20];
  Branch -> Warehouse [style=invis, weight=20];
  Warehouse -> WarehouseAccess [style=invis, weight=20];
  WarehouseAccess -> WarehouseLayout [style=invis, weight=20];
  StorageZoneType -> StorageZone [style=invis, weight=20];
  StorageZone -> StorageLocation [style=invis, weight=20];
  StorageLocation -> StorageObject [style=invis, weight=20];
  Brand -> Category [style=invis, weight=20];
  Category -> Product [style=invis, weight=20];
  Product -> ProductChangeLog [style=invis, weight=20];
  VehicleMake -> VehicleModel [style=invis, weight=20];
  VehicleModel -> ProductApplicability [style=invis, weight=20];
  ProductApplicability -> ProductCrossReference [style=invis, weight=20];
  Receiving -> ReceivingLine [style=invis, weight=20];
  ReceivingLine -> ReceivingSerial [style=invis, weight=20];
  ReceivingSerial -> Stock [style=invis, weight=20];
  Stock -> StockMovement [style=invis, weight=20];
  Inventory -> InventoryLine [style=invis, weight=20];
  InventoryLine -> Order [style=invis, weight=20];
  Order -> OrderLine [style=invis, weight=20];
  OrderLine -> Backorder [style=invis, weight=20];
