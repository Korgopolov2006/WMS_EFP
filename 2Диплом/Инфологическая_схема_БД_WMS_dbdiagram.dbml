Project "WMS_Infological" {
  database_type: 'Инфологическая модель'
  Note: 'Инфологическая схема БД WMS: русские наименования сущностей и атрибутов, без первичных и внешних ключей, индексов и технических ограничений.'
}

Table "Пользователи" [note: 'Сотрудники и учетные записи системы'] {
  "Логин" text
  "Имя" text
  "Фамилия" text
  "Email" text
  "Роль" text
  "Статус активности" boolean
  "Дата регистрации" datetime
}

Table "Филиалы" [note: 'Филиалы организации'] {
  "Код филиала" text
  "Название филиала" text
  "Адрес" text
  "Статус активности" boolean
}

Table "Склады" [note: 'Склады филиалов'] {
  "Филиал" text
  "Код склада" text
  "Название склада" text
  "Ширина" number
  "Длина" number
  "Высота" number
  "Статус активности" boolean
}

Table "Доступы к складам" [note: 'Права пользователей на работу со складами'] {
  "Пользователь" text
  "Склад" text
  "Уровень доступа" text
}

Table "Бренды" [note: 'Производители автозапчастей'] {
  "Название бренда" text
}

Table "Категории товаров" [note: 'Группы номенклатуры'] {
  "Название категории" text
  "Родительская категория" text
}

Table "Марки автомобилей" [note: 'Марки транспортных средств'] {
  "Название марки" text
}

Table "Модели автомобилей" [note: 'Модели транспортных средств'] {
  "Марка автомобиля" text
  "Название модели" text
}

Table "Типы складских зон" [note: 'Виды зон хранения'] {
  "Код типа зоны" text
  "Название типа зоны" text
  "Описание" text
  "Порядок отображения" number
}

Table "Зоны хранения" [note: 'Зоны внутри склада'] {
  "Склад" text
  "Тип зоны" text
  "Код зоны" text
  "Название зоны" text
  "Описание" text
}

Table "Места хранения" [note: 'Складские ячейки и места размещения'] {
  "Зона хранения" text
  "Код места" text
  "Наименование места" text
  "Ряд" text
  "Стеллаж" text
  "Полка" text
  "Уровень" text
  "Максимальный вес" number
}

Table "Товары" [note: 'Номенклатура автозапчастей'] {
  "Внутренний артикул" text
  "Наименование товара" text
  "OEM номер" text
  "Номер аналога" text
  "Штрихкод" text
  "Бренд" text
  "Категория" text
  "Вес" number
  "Длина" number
  "Ширина" number
  "Высота" number
  "Тип упаковки" text
  "Фото товара" text
}

Table "Применимость товаров" [note: 'Связь товаров с моделями автомобилей'] {
  "Товар" text
  "Модель автомобиля" text
}

Table "Аналоги товаров" [note: 'Перекрестные ссылки между товарами'] {
  "Исходный товар" text
  "Связанный товар" text
  "Тип связи" text
  "Комментарий" text
}

Table "Журнал изменений товаров" [note: 'История изменения карточек товаров'] {
  "Товар" text
  "Пользователь" text
  "Действие" text
  "Источник изменения" text
  "Измененные поля" text
  "Комментарий" text
  "Дата изменения" datetime
}

Table "Поставщики" [note: 'Контрагенты, поставляющие товар'] {
  "Код поставщика" text
  "Название поставщика" text
  "Статус активности" boolean
}

Table "Приемки" [note: 'Документы поступления товара'] {
  "Номер приемки" text
  "Поставщик" text
  "Номер документа поставщика" text
  "Склад" text
  "Статус приемки" text
  "Плановая дата поставки" datetime
  "Дата завершения" datetime
  "Создал" text
}

Table "Строки приемки" [note: 'Товары в документе приемки'] {
  "Приемка" text
  "Товар" text
  "Артикул поставщика" text
  "Ожидаемое количество" number
  "Принятое количество" number
  "Место хранения" text
  "Наличие серийных номеров" boolean
}

Table "Серийные номера приемки" [note: 'Серийные номера принятых товаров'] {
  "Строка приемки" text
  "Серийный номер" text
}

Table "Остатки" [note: 'Текущие складские остатки'] {
  "Товар" text
  "Место хранения" text
  "Доступное количество" number
  "Зарезервированное количество" number
  "Номер партии" text
  "Срок годности" date
}

Table "Инвентаризации" [note: 'Документы проверки складских остатков'] {
  "Номер инвентаризации" text
  "Зона хранения" text
  "Статус инвентаризации" text
  "Дата начала" datetime
  "Дата завершения" datetime
  "Создал" text
}

Table "Строки инвентаризации" [note: 'Позиции, проверяемые при инвентаризации'] {
  "Инвентаризация" text
  "Товар" text
  "Место хранения" text
  "Количество по учету" number
  "Фактическое количество" number
  "Расхождение" number
}

Table "Движения товара" [note: 'Журнал складских операций'] {
  "Тип операции" text
  "Статус операции" text
  "Товар" text
  "Количество" number
  "Место списания" text
  "Место поступления" text
  "Партия" text
  "Причина" text
  "Комментарий" text
  "Документ-основание" text
  "Пользователь" text
  "Дата операции" datetime
}

Table "Заказы клиентов" [note: 'Заказы на отгрузку'] {
  "Номер заказа" text
  "Клиент" text
  "Телефон клиента" text
  "Email клиента" text
  "Комментарий" text
  "Статус заказа" text
  "Приоритет" text
  "Срок отгрузки" datetime
  "Источник заказа" text
  "Внешний номер" text
  "Создал" text
  "Подобрал" text
}

Table "Строки заказа" [note: 'Товары, входящие в заказ клиента'] {
  "Заказ" text
  "Товар" text
  "Заказанное количество" number
  "Собранное количество" number
  "Цена" number
}

Table "Задания на сборку" [note: 'Задачи по подбору товара для заказа'] {
  "Заказ" text
  "Статус задания" text
  "Приоритет" text
  "Срок выполнения" datetime
  "Тип зоны" text
  "Назначенный сотрудник" text
  "Дата начала" datetime
  "Дата завершения" datetime
}

Table "Строки сборки" [note: 'Фактически подобранные товары'] {
  "Задание на сборку" text
  "Строка заказа" text
  "Остаток" text
  "Собранное количество" number
  "Отсканированный OEM" text
}

Table "Отложенные позиции" [note: 'Позиции заказа, не обеспеченные остатками'] {
  "Заказ" text
  "Товар" text
  "Заказанное количество" number
  "Выполненное количество" number
  "Статус" text
  "Ожидаемая дата поступления" date
  "Дата выполнения" datetime
  "Создал" text
  "Примечания" text
}

Table "Инструменты" [note: 'Складские инструменты и оборудование'] {
  "Склад" text
  "Тип инструмента" text
  "Инвентарный номер" text
  "Название инструмента" text
  "Производитель" text
  "Модель" text
  "Доступен" boolean
  "Активен" boolean
  "Текущий пользователь" text
  "Дата выдачи" datetime
  "Ожидаемая дата возврата" datetime
  "Дата последнего ТО" date
  "Дата следующего ТО" date
  "Примечания" text
}

Table "Задачи" [note: 'Рабочие задачи сотрудников склада'] {
  "Тип задачи" text
  "Статус задачи" text
  "Приоритет" text
  "Название задачи" text
  "Описание" text
  "Приемка" text
  "Инвентаризация" text
  "Заказ" text
  "Задание на сборку" text
  "Назначенный сотрудник" text
  "Создал" text
  "Срок выполнения" datetime
  "Дата начала" datetime
  "Дата завершения" datetime
  "Дополнительные данные" text
}

Table "Комментарии к задачам" [note: 'Обсуждение задач'] {
  "Задача" text
  "Автор" text
  "Текст комментария" text
  "Дата комментария" datetime
}

Table "Уведомления" [note: 'Системные уведомления пользователей'] {
  "Пользователь" text
  "Тип уведомления" text
  "Приоритет" text
  "Заголовок" text
  "Текст уведомления" text
  "Ссылка" text
  "Ключ дедупликации" text
  "Прочитано" boolean
  "Дата прочтения" datetime
  "Дата создания" datetime
}

Table "ABC XYZ анализ" [note: 'Аналитика продаж и стабильности спроса'] {
  "Товар" text
  "Начало периода" date
  "Конец периода" date
  "Количество продаж" number
  "Сумма продаж" number
  "ABC класс" text
  "XYZ класс" text
  "Коэффициент вариации" number
}

Table "Мертвые остатки" [note: 'Товары без движения'] {
  "Товар" text
  "Остаток" text
  "Доступное количество" number
  "Дней без движения" number
  "Дата последнего движения" date
  "Оценочная стоимость" number
  "Дата расчета" datetime
}

Table "Ошибки сборки" [note: 'Зафиксированные ошибки подбора'] {
  "Строка заказа" text
  "Строка сборки" text
  "Тип ошибки" text
  "Ожидаемый товар" text
  "Фактический товар" text
  "Ожидаемое количество" number
  "Фактическое количество" number
  "Обнаружил" text
  "Дата обнаружения" datetime
  "Исправлено" boolean
  "Дата исправления" datetime
  "Исправил" text
  "Примечания" text
}

Table "Прогнозы спроса" [note: 'Прогноз потребности в товарах'] {
  "Товар" text
  "Дата прогноза" date
  "Начало периода прогноза" date
  "Конец периода прогноза" date
