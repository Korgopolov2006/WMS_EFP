digraph model_graph {
  // Dotfile by Django-Extensions graph_models
  // Created: 2026-05-12 03:45
  

  fontname = "Arial"
  fontsize = 8
  splines = ortho
  nodesep = 0.95
  ranksep = 1.70
  outputorder = edgesfirst
  concentrate = false
  overlap = false
  rankdir = "LR"
  

  node [
    fontname = "Arial"
    fontsize = 8
    shape = "plaintext"
  ]

  edge [
    fontname = "Arial"
    fontsize = 8
  ]

