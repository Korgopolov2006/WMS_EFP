        <mxCell id="catalog_storagezone" value="&lt;div style=&#x27;text-align:center&#x27;&gt;&lt;b&gt;catalog_storagezone&lt;/b&gt;&lt;/div&gt;&lt;hr size=&#x27;1&#x27;&gt;PK id BIGINT&lt;br&gt;FK warehouse_id -&amp;gt; catalog_warehouse.id&lt;br&gt;FK zone_type_id -&amp;gt; catalog_storagezonetype.id&lt;br&gt;code VARCHAR(32)&lt;br&gt;name VARCHAR(120)&lt;br&gt;UNIQUE(warehouse_id, code) WHERE warehouse_id IS NOT NULL&lt;br&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=13;align=left;verticalAlign=top;spacing=8;" parent="1" vertex="1"><mxGeometry x="1200" y="380" width="360" height="180" as="geometry" /></mxCell>
