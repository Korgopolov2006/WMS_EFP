        <mxCell id="catalog_product" value="&lt;div style=&#x27;text-align:center&#x27;&gt;&lt;b&gt;catalog_product&lt;/b&gt;&lt;/div&gt;&lt;hr size=&#x27;1&#x27;&gt;PK id BIGINT&lt;br&gt;internal_sku VARCHAR(64) UNIQUE&lt;br&gt;name VARCHAR(255)&lt;br&gt;oem_number VARCHAR(64) INDEX&lt;br&gt;analog_number VARCHAR(64) INDEX&lt;br&gt;barcode VARCHAR(64) UNIQUE WHERE &amp;lt;&amp;gt; &amp;#x27;&amp;#x27;&lt;br&gt;FK brand_id -&amp;gt; catalog_brand.id&lt;br&gt;FK category_id -&amp;gt; catalog_category.id&lt;br&gt;packaging_type VARCHAR(16)&lt;br&gt;INDEX(brand_id, category_id)&lt;br&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=13;align=left;verticalAlign=top;spacing=8;" parent="1" vertex="1"><mxGeometry x="700" y="610" width="390" height="255" as="geometry" /></mxCell>
