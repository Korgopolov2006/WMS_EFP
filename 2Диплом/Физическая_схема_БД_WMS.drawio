        <mxCell id="catalog_productapplicability" value="&lt;div style=&#x27;text-align:center&#x27;&gt;&lt;b&gt;catalog_productapplicability&lt;/b&gt;&lt;/div&gt;&lt;div style=&#x27;text-align:center;font-size:11px&#x27;&gt;N:M product-vehicle&lt;/div&gt;&lt;hr size=&#x27;1&#x27;&gt;PK id BIGINT&lt;br&gt;FK product_id -&amp;gt; catalog_product.id&lt;br&gt;FK vehicle_model_id -&amp;gt; catalog_vehiclemodel.id&lt;br&gt;UNIQUE(product_id, vehicle_model_id)&lt;br&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=13;align=left;verticalAlign=top;spacing=8;" parent="1" vertex="1"><mxGeometry x="700" y="920" width="360" height="135" as="geometry" /></mxCell>
        <mxCell id="catalog_productcrossreference" value="&lt;div style=&#x27;text-align:center&#x27;&gt;&lt;b&gt;catalog_productcrossreference&lt;/b&gt;&lt;/div&gt;&lt;div style=&#x27;text-align:center;font-size:11px&#x27;&gt;self N:M&lt;/div&gt;&lt;hr size=&#x27;1&#x27;&gt;PK id BIGINT&lt;br&gt;FK from_product_id -&amp;gt; catalog_product.id&lt;br&gt;FK to_product_id -&amp;gt; catalog_product.id&lt;br&gt;relation_type VARCHAR(16)&lt;br&gt;CHECK from_product_id &amp;lt;&amp;gt; to_product_id&lt;br&gt;UNIQUE(from_product_id, to_product_id, relation_type)&lt;br&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=13;align=left;verticalAlign=top;spacing=8;" parent="1" vertex="1"><mxGeometry x="1120" y="920" width="380" height="170" as="geometry" /></mxCell>
        <mxCell id="inventory_stock" value="&lt;div style=&#x27;text-align:center&#x27;&gt;&lt;b&gt;inventory_stock&lt;/b&gt;&lt;/div&gt;&lt;hr size=&#x27;1&#x27;&gt;PK id BIGINT&lt;br&gt;FK product_id -&amp;gt; catalog_product.id&lt;br&gt;FK storage_location_id -&amp;gt; catalog_storagelocation.id&lt;br&gt;qty_available NUMERIC(10,2)&lt;br&gt;qty_reserved NUMERIC(10,2)&lt;br&gt;batch_no VARCHAR(64)&lt;br&gt;UNIQUE(product_id, storage_location_id, batch_no)&lt;br&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=13;align=left;verticalAlign=top;spacing=8;" parent="1" vertex="1"><mxGeometry x="1200" y="930" width="360" height="180" as="geometry" /></mxCell>
        <mxCell id="inventory_stockmovement" value="&lt;div style=&#x27;text-align:center&#x27;&gt;&lt;b&gt;inventory_stockmovement&lt;/b&gt;&lt;/div&gt;&lt;hr size=&#x27;1&#x27;&gt;PK id BIGINT&lt;br&gt;FK product_id -&amp;gt; catalog_product.id&lt;br&gt;FK from_location_id -&amp;gt; catalog_storagelocation.id NULL&lt;br&gt;FK to_location_id -&amp;gt; catalog_storagelocation.id NULL&lt;br&gt;FK user_id -&amp;gt; accounts_user.id NULL&lt;br&gt;movement_type VARCHAR(16)&lt;br&gt;quantity NUMERIC(12,2)&lt;br&gt;CHECK quantity &amp;lt;&amp;gt; 0&lt;br&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=13;align=left;verticalAlign=top;spacing=8;" parent="1" vertex="1"><mxGeometry x="1200" y="1170" width="380" height="205" as="geometry" /></mxCell>
