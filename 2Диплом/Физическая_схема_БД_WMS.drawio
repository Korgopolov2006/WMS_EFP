        <mxCell id="receiving_receivingline" value="&lt;div style=&#x27;text-align:center&#x27;&gt;&lt;b&gt;receiving_receivingline&lt;/b&gt;&lt;/div&gt;&lt;hr size=&#x27;1&#x27;&gt;PK id BIGINT&lt;br&gt;FK receiving_id -&amp;gt; receiving_receiving.id&lt;br&gt;FK product_id -&amp;gt; catalog_product.id&lt;br&gt;FK storage_location_id -&amp;gt; catalog_storagelocation.id NULL&lt;br&gt;qty_expected NUMERIC(10,2)&lt;br&gt;qty_received NUMERIC(10,2)&lt;br&gt;has_serial_numbers BOOLEAN&lt;br&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=13;align=left;verticalAlign=top;spacing=8;" parent="1" vertex="1"><mxGeometry x="470" y="1120" width="380" height="180" as="geometry" /></mxCell>
