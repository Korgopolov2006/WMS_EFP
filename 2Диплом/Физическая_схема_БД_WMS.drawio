        <mxCell id="picking_order" value="&lt;div style=&#x27;text-align:center&#x27;&gt;&lt;b&gt;picking_order&lt;/b&gt;&lt;/div&gt;&lt;hr size=&#x27;1&#x27;&gt;PK id BIGINT&lt;br&gt;number VARCHAR(32) UNIQUE INDEX&lt;br&gt;customer_name VARCHAR(255)&lt;br&gt;status VARCHAR(16) INDEX&lt;br&gt;priority VARCHAR(16) INDEX&lt;br&gt;FK created_by_id -&amp;gt; accounts_user.id&lt;br&gt;FK picked_by_id -&amp;gt; accounts_user.id NULL&lt;br&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=13;align=left;verticalAlign=top;spacing=8;" parent="1" vertex="1"><mxGeometry x="60" y="1420" width="360" height="180" as="geometry" /></mxCell>
        <mxCell id="picking_orderline" value="&lt;div style=&#x27;text-align:center&#x27;&gt;&lt;b&gt;picking_orderline&lt;/b&gt;&lt;/div&gt;&lt;hr size=&#x27;1&#x27;&gt;PK id BIGINT&lt;br&gt;FK order_id -&amp;gt; picking_order.id&lt;br&gt;FK product_id -&amp;gt; catalog_product.id&lt;br&gt;qty_ordered NUMERIC(10,2)&lt;br&gt;qty_picked NUMERIC(10,2)&lt;br&gt;price NUMERIC(10,2)&lt;br&gt;UNIQUE(order_id, product_id)&lt;br&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=13;align=left;verticalAlign=top;spacing=8;" parent="1" vertex="1"><mxGeometry x="470" y="1420" width="360" height="180" as="geometry" /></mxCell>
