# Django
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# PostgreSQL
POSTGRES_DB=wms_autoparts
POSTGRES_USER=postgres
POSTGRES_PASSWORD=1
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Альтернатива: единая строка подключения (имеет приоритет над POSTGRES_*)
# DATABASE_URL=postgresql://postgres:1@localhost:5432/wms_autoparts

# Cache / Queue (опционально)
# Если не задано, используется in-memory cache.
# DJANGO_CACHE_URL=redis://127.0.0.1:6379/0

# Celery (опционально)
# Если Redis недоступен, EFP-проверка автоматически перейдёт в локальный фоновый поток.
# CELERY_BROKER_URL=redis://127.0.0.1:6379/1
# CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
# EFP_ALLOW_THREAD_FALLBACK=0
